/*
 * =====================================================================
 * File: generate_host_app_signed_header.c
 * Purpose: NXP HSE Secure Boot Header Generation Implementation
 * Crypto: WolfSSL (SHA-256, Ed25519) + mbedTLS (RSA)
 * 
 * KEY SIGNING FLOW:
 *   1. buildSignerInfo() generates fresh SUBJECT keypair
 *   2. buildSignerInfo() signs 282-byte SignerInfo input with ROOT key
 *   3. generateAppSignedHeader() signs entire header with SUBJECT key
 * =====================================================================
 */

#include "generate_host_app_signed_header.h"
#include <mbedtls/rsa.h>
#include <mbedtls/ctr_drbg.h>
#include <mbedtls/entropy.h>

/* =====================================================================
 * SECTION 1: GLOBAL STAGING BUFFER
 * =====================================================================*/

uint8_t AppSignedHeaderBuffer[APP_SIGNED_HEADER_STAGING_SIZE] = {0};

/* =====================================================================
 * SECTION 2: SUBJECT KEY STORAGE
 * =====================================================================*/

static uint8_t g_subjectEdPriv[64] = {0};
static mbedtls_rsa_context g_subjectRsaCtx;
static uint8_t g_subjectRsaReady = 0;
static uint8_t g_subjectIsEd25519 = 0;
static uint8_t g_subjectKeyReady = 0;

/* =====================================================================
 * SECTION 3: SHA-256 COMPUTATION (WOLFSSL)
 * =====================================================================*/

AppStatus_t sha256Compute(
    const uint8_t *data,
    uint32_t len,
    uint8_t digest[32]
)
{
    wc_Sha256 sha256;
    int ret;

    if (data == NULL || digest == NULL) {
        return APP_NULL_PTR;
    }

    ret = wc_InitSha256(&sha256);
    if (ret != 0) {
        return APP_CRYPTO_FAIL;
    }

    ret = wc_Sha256Update(&sha256, data, len);
    if (ret != 0) {
        wc_Sha256Free(&sha256);
        return APP_HASH_FAIL;
    }

    ret = wc_Sha256Final(&sha256, digest);
    wc_Sha256Free(&sha256);

    if (ret != 0) {
        return APP_HASH_FAIL;
    }

    return APP_OK;
}

/* =====================================================================
 * SECTION 4: ED25519 KEY GENERATION (WOLFSSL)
 * =====================================================================*/

AppStatus_t edGenKeyPair(
    uint8_t privOut[64],
    uint8_t pubOut[32]
)
{
    ed25519_key key;
    WC_RNG rng;
    int ret;
    word32 privLen = 64;
    word32 pubLen = 32;

    if (privOut == NULL || pubOut == NULL) {
        return APP_NULL_PTR;
    }

    ret = wc_InitRng(&rng);
    if (ret != 0) {
        return APP_CRYPTO_FAIL;
    }

    ret = wc_ed25519_init(&key);
    if (ret != 0) {
        wc_FreeRng(&rng);
        return APP_KEY_GEN_FAIL;
    }

    ret = wc_ed25519_make_key(&rng, ED25519_KEY_SIZE, &key);
    if (ret != 0) {
        wc_ed25519_free(&key);
        wc_FreeRng(&rng);
        return APP_KEY_GEN_FAIL;
    }

    ret = wc_ed25519_export_key(&key, privOut, &privLen, pubOut, &pubLen);
    if (ret != 0) {
        wc_ed25519_free(&key);
        wc_FreeRng(&rng);
        return APP_KEY_GEN_FAIL;
    }

    wc_ed25519_free(&key);
    wc_FreeRng(&rng);

    return APP_OK;
}

/* =====================================================================
 * SECTION 5: ED25519 SIGNING (WOLFSSL)
 * =====================================================================*/

AppStatus_t edSign(
    const uint8_t *privKey,
    const uint8_t *pubKey,
    const uint8_t *msg,
    uint32_t msgLen,
    uint8_t sigOut[256]
)
{
    ed25519_key key;
    int ret;
    word32 sigLen = ED25519_SIG_SIZE;
    uint8_t sig[ED25519_SIG_SIZE];

    if (privKey == NULL || pubKey == NULL || msg == NULL || sigOut == NULL) {
        return APP_NULL_PTR;
    }

    ret = wc_ed25519_init(&key);
    if (ret != 0) {
        return APP_CRYPTO_FAIL;
    }

    ret = wc_ed25519_import_private_key(privKey, ED25519_KEY_SIZE, pubKey, ED25519_KEY_SIZE, &key);
    if (ret != 0) {
        wc_ed25519_free(&key);
        return APP_CRYPTO_FAIL;
    }

    ret = wc_ed25519_sign_msg(msg, msgLen, sig, &sigLen, &key);
    if (ret != 0) {
        wc_ed25519_free(&key);
        return APP_SIGNATURE_FAIL;
    }

    wc_ed25519_free(&key);

    /* Copy 64-byte signature and pad to 256 bytes */
    memset(sigOut, 0, 256);
    memcpy(sigOut, sig, ED25519_SIG_SIZE);

    return APP_OK;
}

/* =====================================================================
 * SECTION 6: ED25519 ROOT SIGNING (WOLFSSL)
 * =====================================================================*/

AppStatus_t edRootSign(
    const uint8_t *msg,
    uint32_t msgLen,
    uint8_t sigOut[256]
)
{
    return edSign(ROOT_EDDSA_PRIV_BYTES, ROOT_EDDSA_PUB_BYTES, msg, msgLen, sigOut);
}

/* =====================================================================
 * SECTION 7: RSA KEY GENERATION (MBEDTLS)
 * =====================================================================*/

AppStatus_t rsaGenKeyPair(
    uint8_t pubOut[256],
    WC_RNG *wc_rng,
    mbedtls_rsa_context *outCtx
)
{
    mbedtls_entropy_context entropy;
    mbedtls_ctr_drbg_context drbg;
    int ret;
    unsigned char seed[32];

    if (pubOut == NULL || wc_rng == NULL || outCtx == NULL) {
        return APP_NULL_PTR;
    }

    /* Initialize mbedTLS entropy and DRBG */
    mbedtls_entropy_init(&entropy);
    mbedtls_ctr_drbg_init(&drbg);

    /* Seed DRBG with entropy from WolfSSL RNG */
    if (wc_RNG_GenerateBlock(wc_rng, seed, 32) != 0) {
        mbedtls_ctr_drbg_free(&drbg);
        mbedtls_entropy_free(&entropy);
        return APP_CRYPTO_FAIL;
    }

    ret = mbedtls_ctr_drbg_seed(&drbg, mbedtls_entropy_func, &entropy, seed, 32);
    if (ret != 0) {
        mbedtls_ctr_drbg_free(&drbg);
        mbedtls_entropy_free(&entropy);
        return APP_CRYPTO_FAIL;
    }

    /* Initialize RSA context */
    mbedtls_rsa_init(outCtx, MBEDTLS_RSA_PKCS_V15, MBEDTLS_MD_SHA256);

    /* Generate RSA key pair (2048-bit) */
    ret = mbedtls_rsa_gen_key(outCtx, mbedtls_ctr_drbg_random, &drbg, 
                              RSA_KEY_BITS, RSA_PUB_EXPONENT);
    if (ret != 0) {
        mbedtls_rsa_free(outCtx);
        mbedtls_ctr_drbg_free(&drbg);
        mbedtls_entropy_free(&entropy);
        return APP_KEY_GEN_FAIL;
    }

    /* Export public modulus N (256 bytes) */
    ret = mbedtls_mpi_write_binary(&outCtx->N, pubOut, 256);
    if (ret != 0) {
        mbedtls_rsa_free(outCtx);
        mbedtls_ctr_drbg_free(&drbg);
        mbedtls_entropy_free(&entropy);
        return APP_KEY_GEN_FAIL;
    }

    /* Keep context alive; caller will free entropy and DRBG */
    mbedtls_ctr_drbg_free(&drbg);
    mbedtls_entropy_free(&entropy);

    return APP_OK;
}

/* =====================================================================
 * SECTION 8: RSA SIGNING (MBEDTLS) - SUBJECT KEY
 * =====================================================================*/

AppStatus_t rsaSign(
    const uint8_t *msg,
    uint32_t msgLen,
    uint8_t sigOut[256],
    mbedtls_rsa_context *ctx,
    WC_RNG *wc_rng
)
{
    mbedtls_entropy_context entropy;
    mbedtls_ctr_drbg_context drbg;
    int ret;
    unsigned char hash[32];
    unsigned char seed[32];

    if (msg == NULL || sigOut == NULL || ctx == NULL || wc_rng == NULL) {
        return APP_NULL_PTR;
    }

    /* Compute SHA-256 of message */
    ret = sha256Compute(msg, msgLen, hash);
    if (ret != APP_OK) {
        return ret;
    }

    /* Initialize entropy and DRBG for signing */
    mbedtls_entropy_init(&entropy);
    mbedtls_ctr_drbg_init(&drbg);

    /* Seed DRBG */
    if (wc_RNG_GenerateBlock(wc_rng, seed, 32) != 0) {
        mbedtls_ctr_drbg_free(&drbg);
        mbedtls_entropy_free(&entropy);
        return APP_CRYPTO_FAIL;
    }

    ret = mbedtls_ctr_drbg_seed(&drbg, mbedtls_entropy_func, &entropy, seed, 32);
    if (ret != 0) {
        mbedtls_ctr_drbg_free(&drbg);
        mbedtls_entropy_free(&entropy);
        return APP_CRYPTO_FAIL;
    }

    /* PKCS#1 v1.5 sign with SHA-256 */
    ret = mbedtls_rsa_pkcs1_sign(ctx, mbedtls_ctr_drbg_random, &drbg,
                                 MBEDTLS_RSA_PRIVATE, MBEDTLS_MD_SHA256, 32, 
                                 hash, sigOut);

    mbedtls_ctr_drbg_free(&drbg);
    mbedtls_entropy_free(&entropy);

    if (ret != 0) {
        return APP_SIGNATURE_FAIL;
    }

    return APP_OK;
}

/* =====================================================================
 * SECTION 9: RSA ROOT SIGNING (MBEDTLS)
 * =====================================================================*/

AppStatus_t rsaRootSign(
    const uint8_t *msg,
    uint32_t msgLen,
    uint8_t sigOut[256]
)
{
    mbedtls_rsa_context ctx;
    mbedtls_entropy_context entropy;
    mbedtls_ctr_drbg_context drbg;
    int ret;
    unsigned char hash[32];
    unsigned char seed[32];
    WC_RNG wc_rng;

    if (msg == NULL || sigOut == NULL) {
        return APP_NULL_PTR;
    }

    /* Initialize WolfSSL RNG */
    ret = wc_InitRng(&wc_rng);
    if (ret != 0) {
        return APP_CRYPTO_FAIL;
    }

    /* Compute SHA-256 of message */
    ret = sha256Compute(msg, msgLen, hash);
    if (ret != APP_OK) {
        wc_FreeRng(&wc_rng);
        return ret;
    }

    /* Initialize mbedTLS entropy and DRBG */
    mbedtls_entropy_init(&entropy);
    mbedtls_ctr_drbg_init(&drbg);

    /* Seed DRBG with entropy from WolfSSL RNG */
    if (wc_RNG_GenerateBlock(&wc_rng, seed, 32) != 0) {
        mbedtls_ctr_drbg_free(&drbg);
        mbedtls_entropy_free(&entropy);
        wc_FreeRng(&wc_rng);
        return APP_CRYPTO_FAIL;
    }

    ret = mbedtls_ctr_drbg_seed(&drbg, mbedtls_entropy_func, &entropy, seed, 32);
    if (ret != 0) {
        mbedtls_ctr_drbg_free(&drbg);
        mbedtls_entropy_free(&entropy);
        wc_FreeRng(&wc_rng);
        return APP_CRYPTO_FAIL;
    }

    /* Initialize RSA context */
    mbedtls_rsa_init(&ctx, MBEDTLS_RSA_PKCS_V15, MBEDTLS_MD_SHA256);

    /* Import root RSA key components using mbedtls_rsa_import_raw */
    ret = mbedtls_rsa_import_raw(&ctx,
                                 ROOT_RSA_PUB_BYTES, 256,   /* N (modulus) */
                                 NULL, 0,                    /* P */
                                 NULL, 0,                    /* Q */
                                 ROOT_RSA_PRIV_BYTES, 256,   /* D (private exponent) */
                                 (const unsigned char *)&g_rsa_e, sizeof(uint32_t));  /* E */
    if (ret != 0) {
        mbedtls_rsa_free(&ctx);
        mbedtls_ctr_drbg_free(&drbg);
        mbedtls_entropy_free(&entropy);
        wc_FreeRng(&wc_rng);
        return APP_CRYPTO_FAIL;
    }

    /* Complete RSA context (compute CRT parameters if needed) */
    ret = mbedtls_rsa_complete(&ctx);
    if (ret != 0 && ret != MBEDTLS_ERR_RSA_BAD_INPUT_DATA) {
        /* If complete fails, proceed anyway - we only need N and D */
    }

    /* PKCS#1 v1.5 sign with SHA-256 */
    ret = mbedtls_rsa_pkcs1_sign(&ctx, mbedtls_ctr_drbg_random, &drbg,
                                 MBEDTLS_RSA_PRIVATE, MBEDTLS_MD_SHA256, 32,
                                 hash, sigOut);

    mbedtls_rsa_free(&ctx);
    mbedtls_ctr_drbg_free(&drbg);
    mbedtls_entropy_free(&entropy);
    wc_FreeRng(&wc_rng);

    if (ret != 0) {
        return APP_SIGNATURE_FAIL;
    }

    return APP_OK;
}

/* Add global for RSA exponent E */
static uint32_t g_rsa_e = RSA_PUB_EXPONENT;  /* 65537 in big-endian */

/* =====================================================================
 * SECTION 10: BUILD SIGNER INFO
 * =====================================================================*/

AppStatus_t buildSignerInfo(
    SignerInfo_t *signerInfo,
    uint16_t keySize
)
{
    uint8_t privKey[64];
    uint8_t pubKey[32];
    uint8_t signerInfoInput[282];
    AppStatus_t status;
    WC_RNG rng;
    int ret;

    if (signerInfo == NULL) {
        return APP_NULL_PTR;
    }

    memset(signerInfo, 0, sizeof(SignerInfo_t));

    /* Initialize RNG */
    ret = wc_InitRng(&rng);
    if (ret != 0) {
        return APP_CRYPTO_FAIL;
    }

    /* --- GENERATE SUBJECT KEYPAIR --- */
    if (keySize == KEY_SIZE_EDDSA) {
        /* Generate Ed25519 subject key */
        status = edGenKeyPair(privKey, pubKey);
        if (status != APP_OK) {
            wc_FreeRng(&rng);
            return status;
        }

        /* Store subject private key for later header signing */
        memcpy(g_subjectEdPriv, privKey, 64);
        g_subjectIsEd25519 = 1;
        g_subjectKeyReady = 1;

        /* Store public key in signer info (pad to 256 bytes) */
        memset(signerInfo->subjectPublicKey, 0, 256);
        memcpy(signerInfo->subjectPublicKey, pubKey, 32);

    } else if (keySize == KEY_SIZE_RSA2048) {
        /* Generate RSA-2048 subject key */
        status = rsaGenKeyPair(signerInfo->subjectPublicKey, &rng, &g_subjectRsaCtx);
        if (status != APP_OK) {
            wc_FreeRng(&rng);
            return status;
        }

        /* Store state for later header signing */
        g_subjectIsEd25519 = 0;
        g_subjectRsaReady = 1;
        g_subjectKeyReady = 1;

    } else {
        wc_FreeRng(&rng);
        return APP_INVALID_CMD;
    }

    /* --- FILL FIXED FIELDS --- */
    memcpy(signerInfo->subjectName, VALID_SUBJECT_NAME, 16);

    /* Write CERT_ID (8 bytes, big-endian) */
    writeBE32(signerInfo->certificateID, (uint32_t)(VALID_CERT_ID >> 32));
    writeBE32(signerInfo->certificateID + 4, (uint32_t)(VALID_CERT_ID & 0xFFFFFFFF));

    writeBE16(signerInfo->keyNBID, VALID_KEY_NBID);

    /* --- ASSEMBLE 282-BYTE SIGNER INFO INPUT --- */
    memcpy(signerInfoInput + 0,   signerInfo->subjectName,      16);
    memcpy(signerInfoInput + 16,  signerInfo->certificateID,    8);
    memcpy(signerInfoInput + 24,  signerInfo->keyNBID,          2);
    memcpy(signerInfoInput + 26,  signerInfo->subjectPublicKey, 256);

    /* --- SIGN WITH ROOT KEY --- */
    if (keySize == KEY_SIZE_EDDSA) {
        status = edRootSign(signerInfoInput, 282, signerInfo->rootSignature);
    } else {
        status = rsaRootSign(signerInfoInput, 282, signerInfo->rootSignature);
    }

    wc_FreeRng(&rng);

    if (status != APP_OK) {
        return APP_SIGNER_INFO_FAIL;
    }

    return APP_OK;
}

/* =====================================================================
 * SECTION 11: SIGN HEADER CONTENT (USING SUBJECT KEY)
 * =====================================================================*/

static AppStatus_t signHeaderContent(
    const uint8_t *headerContent,
    uint32_t contentLen,
    uint16_t keySize,
    uint8_t sigOut[256]
)
{
    AppStatus_t status;
    WC_RNG rng;
    int ret;

    if (headerContent == NULL || sigOut == NULL) {
        return APP_NULL_PTR;
    }

    /* Initialize RNG */
    ret = wc_InitRng(&rng);
    if (ret != 0) {
        return APP_CRYPTO_FAIL;
    }

    if (keySize == KEY_SIZE_EDDSA && g_subjectIsEd25519 && g_subjectKeyReady) {
        /* Use retained subject Ed25519 private key */
        uint8_t pubKey[32];
        memcpy(pubKey, g_subjectEdPriv + 32, 32);

        status = edSign(g_subjectEdPriv, pubKey, headerContent, contentLen, sigOut);

    } else if (keySize == KEY_SIZE_RSA2048 && g_subjectRsaReady && g_subjectKeyReady) {
        /* Use retained subject RSA context */
        status = rsaSign(headerContent, contentLen, sigOut, &g_subjectRsaCtx, &rng);

        /* Free RSA context after use */
        mbedtls_rsa_free(&g_subjectRsaCtx);
        g_subjectRsaReady = 0;

    } else {
        wc_FreeRng(&rng);
        return APP_SIGNATURE_FAIL;
    }

    wc_FreeRng(&rng);

    /* Clear subject key state */
    memset(g_subjectEdPriv, 0, 64);
    g_subjectKeyReady = 0;

    return status;
}

/* =====================================================================
 * SECTION 12: APPLY NEGATIVE OVERRIDES
 * =====================================================================*/

AppStatus_t applyNegativeOverrides(
    AppSignedHeader_t *header,
    uint8_t negativeCase
)
{
    if (header == NULL) {
        return APP_NULL_PTR;
    }

    switch (negativeCase) {
        case INVALID_MESSAGE_DIGEST:
            memset(header->messageDigest, 0x00, 32);
            break;
        case INVALID_MODULE_ID:
            memset(header->moduleId, 0x00, 2);
            break;
        case INVALID_ECU_ID_CASE:
            memset(header->ecuId, 0x00, 16);
            break;
        case INVALID_ECU_NAME_CASE:
            memset(header->ecuName, 0x00, 8);
            break;
        case INVALID_APP_NBID_CASE:
            memset(header->appNbid, 0x00, 2);
            break;
        case INVALID_SIGNER_INFO:
            memset(&header->signerInfo, 0x00, 538);
            break;
        case INVALID_REGION_INFO:
        case INVALID_SW_LOCATION:
            if (header->numSwRegions[1] > 0) {
                memset(&header->hseFwRegionInfo[0], 0x00, 8);
            }
            break;
        case INVALID_HOST_SIGNATURE:
            memset(header->headerSignature, 0x00, 256);
            break;
        case NEGATIVE_NONE:
        default:
            break;
    }

    return APP_OK;
}

/* =====================================================================
 * SECTION 13: GENERATE NORMAL HEADER (882 BYTES)
 * =====================================================================*/

AppStatus_t generateAppSignedHeader(
    AppSignedHeader_t *header,
    uint16_t keySize,
    uint16_t moduleId,
    uint8_t negativeCase,
    AppErrorContext_t *errCtx
)
{
    uint16_t Version_be;
    uint32_t numModOff, firstModOff, regionInfoOff;
    uint16_t numModules_be, numModules_le;
    uint32_t RegionAddressInfo[100] = {0};
    uint32_t RegionLocationInfo[100] = {0};
    uint8_t numRegions = 0;
    uint16_t ModuleId_be, ModuleId_le;
    uint16_t RegionOffset_be, RegionOffset_le = 0;
    uint8_t ModuleFound = 0;
    uint32_t Address_be, Length_be;
    uint8_t *MDaddr;
    uint32_t MDLength = 0;
    uint8_t msgDigest[32];
    AppStatus_t status;
    uint32_t signLength;
    int i;

    if (header == NULL || errCtx == NULL) {
        return APP_NULL_PTR;
    }

    memset(errCtx, 0, sizeof(AppErrorContext_t));

    /* ========== STEP 1: READ SBIT VERSION ========== */
    uint16_t *TableVersion_ptr = (uint16_t *)(SBIT_ADDRESS + 0x00);
    Version_be = *TableVersion_ptr;

    /* ========== STEP 2: SELECT OFFSETS ========== */
    if (Version_be == 0x0255 || Version_be == 0x0355) {
        numModOff = NUMBER_OF_MGAL_SBIT_MODULE_OFFSET;
        firstModOff = FIRST_MODULE_OFFSET_WITH_MGAL;
        regionInfoOff = REGION_INFO_OFFSET_WITH_MGAL;
    } else {
        numModOff = NUMBER_OF_SBIT_MODULE_OFFSET;
        firstModOff = FIRST_MODULE_OFFSET;
        regionInfoOff = REGION_INFO_OFFSET;
    }

    /* ========== STEP 3: READ MODULE COUNT ========== */
    uint16_t *numModules_ptr = (uint16_t *)(SBIT_ADDRESS + numModOff);
    numModules_be = *numModules_ptr;
    numModules_le = CHANGE_ENDIANNESS_16BIT(numModules_be);

    /* ========== STEP 4: SEARCH FOR MODULE ========== */
    for (i = 0; i < numModules_le; i++) {
        uint16_t *ModuleId_ptr = (uint16_t *)(SBIT_ADDRESS + firstModOff + (i * 4));
        uint16_t *RegionOffset_ptr = (uint16_t *)(SBIT_ADDRESS + regionInfoOff + (i * 4));

        ModuleId_be = *ModuleId_ptr;
        ModuleId_le = CHANGE_ENDIANNESS_16BIT(ModuleId_be);

        if (ModuleId_le == moduleId) {
            RegionOffset_be = *RegionOffset_ptr;
            RegionOffset_le = CHANGE_ENDIANNESS_16BIT(RegionOffset_be);
            ModuleFound = 1;
            break;
        }
    }

    /* ========== STEP 5: HANDLE NOT FOUND ========== */
    if (!ModuleFound && negativeCase == INVALID_MODULE_ID) {
        numRegions = FALLBACK_NUM_REGIONS;
        RegionAddressInfo[0] = FALLBACK_REGION_START_ADDR;
        RegionLocationInfo[0] = FALLBACK_REGION_LENGTH;
        ModuleFound = 1;
    } else if (!ModuleFound) {
        errCtx->appStatus = APP_MODULE_NOT_FOUND;
        errCtx->moduleId = moduleId;
        return APP_MODULE_NOT_FOUND;
    }

    /* ========== STEP 6: PARSE REGIONS ========== */
    if (negativeCase != INVALID_MODULE_ID && ModuleFound) {
        uint8_t *NumRegions_ptr = (uint8_t *)(SBIT_ADDRESS + RegionOffset_le + SBIT_MOD_NUM_REGIONS_BYTE_OFF);
        numRegions = *NumRegions_ptr;

        if (numRegions > SBIT_MAX_REGIONS) {
            return APP_REGION_OVERFLOW;
        }

        for (i = 0; i < numRegions; i++) {
            uint32_t *Address_ptr = (uint32_t *)(SBIT_ADDRESS + RegionOffset_le +
                                                   SBIT_MOD_REGION_ADDR_BYTE_BASE + (i * SBIT_MOD_REGION_ENTRY_BYTES));
            uint32_t *Length_ptr = (uint32_t *)(SBIT_ADDRESS + RegionOffset_le +
                                                  SBIT_MOD_REGION_LEN_BYTE_BASE + (i * SBIT_MOD_REGION_ENTRY_BYTES));

            RegionAddressInfo[i] = *Address_ptr;
            RegionLocationInfo[i] = *Length_ptr;
        }
    }

    /* ========== STEP 7: MESSAGE DIGEST ========== */
    MDaddr = (uint8_t *)getAppSignedHeaderAddress();
    MDLength = 0;

    for (i = 0; i < numRegions; i++) {
        memcpy(MDaddr, (uint8_t *)RegionAddressInfo[i], RegionLocationInfo[i]);
        MDaddr += RegionLocationInfo[i];
        MDLength += RegionLocationInfo[i];
    }

    status = sha256Compute((uint8_t *)getAppSignedHeaderAddress(), MDLength, msgDigest);
    if (status != APP_OK) {
        errCtx->appStatus = status;
        errCtx->hashComputationFailed = 1;
        return status;
    }

    /* ========== STEP 8: POPULATE HEADER ========== */
    memset(header, 0, sizeof(AppSignedHeader_t));

    writeBE16(header->moduleId, moduleId);
    writeBE16(header->bcid, VALID_BCID);
    memcpy(header->ecuName, VALID_ECU_NAME, 8);
    memcpy(header->ecuId, VALID_ECU_ID, 16);
    memcpy(header->ecuIdExt, VALID_ECU_ID_EXT, 16);
    writeBE16(header->appNbid, VALID_APP_NBID);
    writeBE16(header->numSwRegions, numRegions);

    for (i = 0; i < numRegions; i++) {
        writeBE32((uint8_t *)&header->hseFwRegionInfo[i].startAddress, RegionAddressInfo[i]);
        writeBE32((uint8_t *)&header->hseFwRegionInfo[i].length, RegionLocationInfo[i]);
    }

    memcpy(header->messageDigest, msgDigest, 32);

    /* ========== STEP 9: BUILD SIGNER INFO ========== */
    status = buildSignerInfo(&header->signerInfo, keySize);
    if (status != APP_OK) {
        errCtx->appStatus = status;
        errCtx->signerInfoFailed = 1;
        return status;
    }

    /* ========== STEP 10: SIGN HEADER WITH SUBJECT KEY ========== */
    signLength = sizeof(header->moduleId) + sizeof(header->bcid) +
                 sizeof(header->ecuName) + sizeof(header->ecuId) +
                 sizeof(header->ecuIdExt) + sizeof(header->appNbid) +
                 sizeof(header->numSwRegions) +
                 (numRegions * sizeof(hseFwRegionInfo_t)) +
                 sizeof(header->messageDigest) + sizeof(header->signerInfo);

    status = signHeaderContent((uint8_t *)header, signLength, keySize, header->headerSignature);
    if (status != APP_OK) {
        errCtx->appStatus = status;
        errCtx->headerSignatureFailed = 1;
        return status;
    }

    /* ========== STEP 11: APPLY NEGATIVE OVERRIDES ========== */
    if (negativeCase != NEGATIVE_NONE) {
        applyNegativeOverrides(header, negativeCase);
    }

    errCtx->appStatus = APP_OK;
    return APP_OK;
}

/* =====================================================================
 * SECTION 14: GENERATE BIT-DIFF HEADER (914 BYTES)
 * =====================================================================*/

AppStatus_t generateAppSignedHeaderBitDiff(
    AppSignedHeaderBitDiff_t *header,
    uint16_t keySize,
    uint16_t moduleId,
    uint8_t negativeCase,
    AppErrorContext_t *errCtx
)
{
    uint16_t Version_be;
    uint32_t numModOff, firstModOff, regionInfoOff;
    uint16_t numModules_be, numModules_le;
    uint32_t RegionAddressInfo[100] = {0};
    uint32_t RegionLocationInfo[100] = {0};
    uint8_t numRegions = 0;
    uint16_t ModuleId_be, ModuleId_le;
    uint16_t RegionOffset_be, RegionOffset_le = 0;
    uint8_t ModuleFound = 0;
    uint8_t *MDaddr;
    uint32_t MDLength = 0;
    uint8_t msgDigest[32];
    AppStatus_t status;
    uint32_t signLength;
    int i;

    if (header == NULL || errCtx == NULL) {
        return APP_NULL_PTR;
    }

    memset(errCtx, 0, sizeof(AppErrorContext_t));

    /* ========== SBIT PARSING ========== */
    uint16_t *TableVersion_ptr = (uint16_t *)(SBIT_ADDRESS + 0x00);
    Version_be = *TableVersion_ptr;

    if (Version_be == 0x0255 || Version_be == 0x0355) {
        numModOff = NUMBER_OF_MGAL_SBIT_MODULE_OFFSET;
        firstModOff = FIRST_MODULE_OFFSET_WITH_MGAL;
        regionInfoOff = REGION_INFO_OFFSET_WITH_MGAL;
    } else {
        numModOff = NUMBER_OF_SBIT_MODULE_OFFSET;
        firstModOff = FIRST_MODULE_OFFSET;
        regionInfoOff = REGION_INFO_OFFSET;
    }

    uint16_t *numModules_ptr = (uint16_t *)(SBIT_ADDRESS + numModOff);
    numModules_be = *numModules_ptr;
    numModules_le = CHANGE_ENDIANNESS_16BIT(numModules_be);

    for (i = 0; i < numModules_le; i++) {
        uint16_t *ModuleId_ptr = (uint16_t *)(SBIT_ADDRESS + firstModOff + (i * 4));
        uint16_t *RegionOffset_ptr = (uint16_t *)(SBIT_ADDRESS + regionInfoOff + (i * 4));

        ModuleId_be = *ModuleId_ptr;
        ModuleId_le = CHANGE_ENDIANNESS_16BIT(ModuleId_be);

        if (ModuleId_le == moduleId) {
            RegionOffset_be = *RegionOffset_ptr;
            RegionOffset_le = CHANGE_ENDIANNESS_16BIT(RegionOffset_be);
            ModuleFound = 1;
            break;
        }
    }

    if (!ModuleFound && negativeCase == INVALID_MODULE_ID) {
        numRegions = FALLBACK_NUM_REGIONS;
        RegionAddressInfo[0] = FALLBACK_REGION_START_ADDR;
        RegionLocationInfo[0] = FALLBACK_REGION_LENGTH;
        ModuleFound = 1;
    } else if (!ModuleFound) {
        errCtx->appStatus = APP_MODULE_NOT_FOUND;
        return APP_MODULE_NOT_FOUND;
    }

    if (negativeCase != INVALID_MODULE_ID && ModuleFound) {
        uint8_t *NumRegions_ptr = (uint8_t *)(SBIT_ADDRESS + RegionOffset_le + SBIT_MOD_NUM_REGIONS_BYTE_OFF);
        numRegions = *NumRegions_ptr;

        if (numRegions > SBIT_MAX_REGIONS) {
            return APP_REGION_OVERFLOW;
        }

        for (i = 0; i < numRegions; i++) {
            uint32_t *Address_ptr = (uint32_t *)(SBIT_ADDRESS + RegionOffset_le +
                                                   SBIT_MOD_REGION_ADDR_BYTE_BASE + (i * SBIT_MOD_REGION_ENTRY_BYTES));
            uint32_t *Length_ptr = (uint32_t *)(SBIT_ADDRESS + RegionOffset_le +
                                                  SBIT_MOD_REGION_LEN_BYTE_BASE + (i * SBIT_MOD_REGION_ENTRY_BYTES));

            RegionAddressInfo[i] = *Address_ptr;
            RegionLocationInfo[i] = *Length_ptr;
        }
    }

    /* ========== MESSAGE DIGEST ========== */
    MDaddr = (uint8_t *)getAppSignedHeaderAddress();
    MDLength = 0;

    for (i = 0; i < numRegions; i++) {
        memcpy(MDaddr, (uint8_t *)RegionAddressInfo[i], RegionLocationInfo[i]);
        MDaddr += RegionLocationInfo[i];
        MDLength += RegionLocationInfo[i];
    }

    status = sha256Compute((uint8_t *)getAppSignedHeaderAddress(), MDLength, msgDigest);
    if (status != APP_OK) {
        return status;
    }

    /* ========== POPULATE BIT-DIFF HEADER ========== */
    memset(header, 0, sizeof(AppSignedHeaderBitDiff_t));

    writeBE16(header->moduleId, moduleId);
    memcpy(header->digestOfFullData, msgDigest, 32);
    writeBE16(header->bcid, VALID_BCID);
    memcpy(header->ecuName, VALID_ECU_NAME, 8);
    memcpy(header->ecuId, VALID_ECU_ID, 16);
    memcpy(header->ecuIdExt, VALID_ECU_ID_EXT, 16);
    writeBE16(header->appNbid, VALID_APP_NBID);
    writeBE16(header->numSwRegions, numRegions);

    for (i = 0; i < numRegions; i++) {
        writeBE32((uint8_t *)&header->hseFwRegionInfo[i].startAddress, RegionAddressInfo[i]);
        writeBE32((uint8_t *)&header->hseFwRegionInfo[i].length, RegionLocationInfo[i]);
    }

    /* Hardcoded all-zeros */
    memset(header->bitDiffEnvelopeDigest, 0x00, 32);

    /* ========== BUILD SIGNER INFO ========== */
    status = buildSignerInfo(&header->signerInfo, keySize);
    if (status != APP_OK) {
        errCtx->appStatus = status;
        return status;
    }

    /* ========== SIGN HEADER ========== */
    signLength = sizeof(header->moduleId) + sizeof(header->digestOfFullData) +
                 sizeof(header->bcid) + sizeof(header->ecuName) + sizeof(header->ecuId) +
                 sizeof(header->ecuIdExt) + sizeof(header->appNbid) +
                 sizeof(header->numSwRegions) +
                 (numRegions * sizeof(hseFwRegionInfo_t)) +
                 sizeof(header->bitDiffEnvelopeDigest) + sizeof(header->signerInfo);

    status = signHeaderContent((uint8_t *)header, signLength, keySize, header->headerSignature);
    if (status != APP_OK) {
        errCtx->appStatus = status;
        return status;
    }

    /* ========== NEGATIVE OVERRIDES ========== */
    if (negativeCase != NEGATIVE_NONE) {
        if (negativeCase == INVALID_MESSAGE_DIGEST) {
            memset(header->digestOfFullData, 0x00, 32);
        }
        if (negativeCase == INVALID_MODULE_ID) {
            memset(header->moduleId, 0x00, 2);
        }
        if (negativeCase == INVALID_SIGNER_INFO) {
            memset(&header->signerInfo, 0x00, 538);
        }
        if (negativeCase == INVALID_HOST_SIGNATURE) {
            memset(header->headerSignature, 0x00, 256);
        }
    }

    errCtx->appStatus = APP_OK;
    return APP_OK;
}

/* =====================================================================
 * SECTION 15: DISPATCHER
 * =====================================================================*/

AppStatus_t getAppSignedHeader(
    uint8_t *headerBuffer,
    uint16_t keySize,
    uint16_t moduleId,
    HeaderType_e headerType,
    uint8_t negativeCase,
    AppErrorContext_t *errCtx
)
{
    AppStatus_t status;

    if (headerBuffer == NULL) {
        return APP_NULL_PTR;
    }

    if (headerType == HEADER_TYPE_NORMAL) {
        AppSignedHeader_t header;
        status = generateAppSignedHeader(&header, keySize, moduleId, negativeCase, errCtx);
        if (status == APP_OK) {
            memcpy(headerBuffer, &header, sizeof(AppSignedHeader_t));
        }
        return status;
    } else if (headerType == HEADER_TYPE_BITDIFF) {
        AppSignedHeaderBitDiff_t header;
        status = generateAppSignedHeaderBitDiff(&header, keySize, moduleId, negativeCase, errCtx);
        if (status == APP_OK) {
            memcpy(headerBuffer, &header, sizeof(AppSignedHeaderBitDiff_t));
        }
        return status;
    }

    return APP_INVALID_CMD;
}

