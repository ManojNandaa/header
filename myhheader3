 * =====================================================================*/

static inline void writeBE16(uint8_t *dst, uint16_t val)
{
    dst[0] = (val >> 8) & 0xFF;
    dst[1] = val & 0xFF;
}

static inline void writeBE32(uint8_t *dst, uint32_t val)
{
    dst[0] = (val >> 24) & 0xFF;
    dst[1] = (val >> 16) & 0xFF;
    dst[2] = (val >> 8) & 0xFF;
    dst[3] = val & 0xFF;
}

